# .env.example - skopiuj do .env i uzupelnij wartosci
# Nigdy nie commituj prawdziwego pliku .env.

# Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Market data
# Dostepne: binance, oanda, exante, demo
SYMBOL=AAPL.NASDAQ
TIMEFRAME=1m
CANDLE_LIMIT=50
MARKET_DATA_SOURCE=exante
BINANCE_BASE_URL=https://api.binance.com

# Broker
BROKER_MODE=exante_demo

# Risk / loop
INTERVAL_SECONDS=60
MAX_POSITION_PCT=0.05
STOP_LOSS_PCT=0.02
MAX_DAILY_LOSS_PCT=0.06
MAX_OPEN_POSITIONS=3
INITIAL_CAPITAL_USD=100000

# Alpaca Paper Trading
# Pobierz paper keys z dashboardu Alpaca: https://app.alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Opcjonalnie nadpisz symbol brokera. Puste = automatycznie z SYMBOL/config.
# Dla domyslnego BTCUSDT broker uzyje BTC/USD.
ALPACA_SYMBOL=BTC/USD
ALPACA_TIME_IN_FORCE=gtc
ALPACA_MIN_ORDER_NOTIONAL=10

# Opcjonalne: Binance Testnet
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=

# Opcjonalne: OANDA Practice
OANDA_ACCOUNT_ID=
OANDA_ACCESS_TOKEN=
OANDA_BASE_URL=https://api-fxpractice.oanda.com
OANDA_INSTRUMENT=EUR_USD
OANDA_MIN_ORDER_UNITS=1

# EXANTE HTTP API Demo
# Utworz klucze demo w Client Area -> Settings -> API Management.
EXANTE_APPLICATION_ID=
EXANTE_ACCESS_KEY=
EXANTE_ACCOUNT_ID=
EXANTE_TRADE_BASE_URL=https://api-demo.exante.eu/trade
EXANTE_MD_BASE_URL=https://api-demo.exante.eu/md
EXANTE_SYMBOL=AAPL.NASDAQ
EXANTE_SUMMARY_CURRENCY=EUR
EXANTE_ORDER_DURATION=day
EXANTE_MIN_ORDER_QUANTITY=1

# Przyklad konfiguracji forex demo OANDA:
# SYMBOL=EUR/USD
# MARKET_DATA_SOURCE=oanda
# BROKER_MODE=oanda_demo
# OANDA_ACCOUNT_ID=...
# OANDA_ACCESS_TOKEN=...
